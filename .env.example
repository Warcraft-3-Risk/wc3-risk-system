# Warcraft III executable path
# Windows:   C:\Program Files (x86)\Warcraft III\_retail_\x86_64\Warcraft III.exe
# macOS:     /Applications/Warcraft III/_retail_/x86_64/Warcraft III.app/Contents/MacOS/Warcraft III
GAME_EXECUTABLE=

# Output folder for built .w3x maps
# Windows:   C:\Users\{USERNAME}\Documents\Warcraft III\Maps\Download\(0) testing
# macOS:     /Users/{USERNAME}/Library/Application Support/Blizzard/Warcraft III/Maps/Download/(0) testing
OUTPUT_FOLDER=

# Map version string injected into the build (e.g., "dev", "4.09")
TAG_NAME=dev

# Set to "true" to enable W3Champions mode
W3C_MODE_ENABLED=false
